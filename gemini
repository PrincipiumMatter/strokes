<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inked & Cherished | Custom Calligraphy & Gifts</title>
    <!-- Tailwind CSS for modern structure -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts for that gorgeous, artistic contrast -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600&family=Montserrat:wght@300;400;500&family=Pinyon+Script&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --color-parchment: #FDFBF7;
            --color-ink: #1C1B1A;
            --color-accent-gold: #C5A880;
            --color-blush: #F5EBE6;
        }

        body {
            font-family: 'Montserrat', sans-serif;
            background-color: var(--color-parchment);
            color: var(--color-ink);
            scroll-behavior: smooth;
        }

        .font-serif-artistic {
            font-family: 'Cinzel', serif;
        }

        .font-calligraphy {
            font-family: 'Pinyon Script', cursive;
        }

        /* Subtle organic backgrounds to mimic handmade paper */
        .paper-texture {
            background-image: radial-gradient(rgba(0,0,0,0.015) 1px, transparent 0), radial-gradient(rgba(0,0,0,0.015) 1px, transparent 0);
            background-size: 8px 8px;
            background-position: 0 0, 4px 4px;
        }

        /* Smooth reveal animation on scroll */
        .reveal {
            opacity: 0;
            transform: translateY(30px);
            transition: all 1s ease;
        }

        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

        /* Custom image placeholders with an artistic stroke */
        .art-placeholder {
            border: 1px dashed var(--color-accent-gold);
            background-color: var(--color-blush);
            position: relative;
            overflow: hidden;
            transition: all 0.4s ease;
        }

        .art-placeholder::after {
            content: 'Your Artwork Here';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-family: 'Cinzel', serif;
            font-size: 0.85rem;
            letter-spacing: 0.1em;
            color: #8C7B6E;
        }

        .art-placeholder:hover {
            border-style: solid;
            transform: scale(1.02);
        }
    </style>
</head>
<body class="paper-texture selection:bg-[#C5A880] selection:text-white">

    <!-- Header / Navigation -->
    <header class="fixed top-0 left-0 w-full z-50 bg-[#FDFBF7]/85 backdrop-blur-md border-b border-[#C5A880]/20 py-5 px-8 flex justify-between items-center">
        <a href="#" class="font-serif-artistic text-xl tracking-widest uppercase">The Ink Studio</a>
        <nav class="hidden md:flex space-x-8 text-xs uppercase tracking-widest font-medium">
            <a href="#about" class="hover:text-[#C5A880] transition">The Story</a>
            <a href="#gallery" class="hover:text-[#C5A880] transition">Gallery</a>
            <a href="#services" class="hover:text-[#C5A880] transition">Services</a>
            <a href="#contact" class="hover:text-[#C5A880] transition">Inquire</a>
        </nav>
        <a href="#contact" class="border border-[#1C1B1A] px-4 py-2 text-xs uppercase tracking-widest hover:bg-[#1C1B1A] hover:text-white transition">Book a Commission</a>
    </header>

    <!-- Hero Section -->
    <section class="min-h-screen flex flex-col justify-center items-center text-center px-6 pt-24 relative overflow-hidden">
        <!-- Abstract ink background accent -->
        <div class="absolute -top-20 -left-20 w-96 h-96 rounded-full bg-[#F5EBE6] filter blur-3xl opacity-60 pointer-events-none"></div>
        <div class="absolute -bottom-20 -right-20 w-96 h-96 rounded-full bg-[#C5A880]/10 filter blur-3xl opacity-60 pointer-events-none"></div>

        <span class="font-calligraphy text-5xl md:text-7xl text-[#C5A880] mb-2 block">crafted by hand</span>
        <h1 class="font-serif-artistic text-4xl md:text-7xl tracking-widest uppercase mb-6 leading-tight max-w-4xl">
            Where ink meets <br> <span class="italic font-light">emotion</span>.
        </h1>
        <p class="text-sm max-w-lg mx-auto leading-relaxed tracking-wide text-neutral-600 mb-10">
            Thoughtfully curated, bespoke gifts and custom calligraphy crafted to turn moments into heirlooms. Made with metallic pigments, fine paper, and pure intent.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
            <a href="#gallery" class="bg-[#1C1B1A] text-white px-8 py-4 text-xs uppercase tracking-widest hover:bg-[#C5A880] transition duration-300">View Selected Works</a>
            <a href="#contact" class="border border-[#1C1B1A] px-8 py-4 text-xs uppercase tracking-widest hover:bg-[#1C1B1A]/5 transition duration-300">Start a Custom Order</a>
        </div>
    </section>

    <!-- About Section -->
    <section id="about" class="py-24 px-6 md:px-12 max-w-6xl mx-auto reveal">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
            <div class="relative">
                <!-- Artist Portrait Placeholder -->
                <div class="art-placeholder h-[450px] w-full rounded-tl-[100px] rounded-br-[100px] shadow-lg"></div>
                <!-- Artistic overlapping element -->
                <div class="absolute -bottom-6 -left-6 bg-white p-6 border border-[#C5A880]/30 hidden md:block">
                    <p class="font-calligraphy text-3xl text-[#C5A880]">With love, always.</p>
                </div>
            </div>
            <div class="space-y-6">
                <span class="font-serif-artistic text-xs uppercase tracking-widest text-[#C5A880] block">— Meet the Artist</span>
                <h2 class="font-serif-artistic text-3xl md:text-4xl tracking-wider uppercase">Slow art for a fast-paced world.</h2>
                <p class="text-sm leading-relaxed text-neutral-600">
                    Hi, I'm [Your Name]. I believe that handwriting is a timestamp of the soul. In an age of fast, digital messages, I find magic in the deliberate scratch of a nib against handmade cotton paper. 
                </p>
                <p class="text-sm leading-relaxed text-neutral-600">
                    Each personalized gift and calligraphed stroke is done with deep focus, premium materials, and a touch of organic chaos that makes it uniquely yours.
                </p>
            </div>
        </div>
    </section>

    <!-- Gallery Section (Minimalist structure, Maximalist sizing) -->
    <section id="gallery" class="py-24 bg-[#F5EBE6]/40 reveal">
        <div class="max-w-7xl mx-auto px-6">
            <div class="text-center mb-16">
                <span class="font-calligraphy text-4xl text-[#C5A880] block mb-2">our curation</span>
                <h2 class="font-serif-artistic text-3xl md:text-4xl uppercase tracking-widest">The Portfolio</h2>
                <div class="w-16 h-[1px] bg-[#C5A880] mx-auto mt-4"></div>
            </div>

            <!-- Asymmetrical Grid for an artistic, editorial feel -->
            <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
                <!-- Tall Portfolio Item -->
                <div class="md:col-span-4 space-y-2">
                    <div class="art-placeholder h-[500px]"></div>
                    <div class="flex justify-between items-center pt-2">
                        <p class="font-serif-artistic text-sm uppercase tracking-wider">Vow Booklets</p>
                        <p class="text-xs text-neutral-500">Gold ink on deckled edges</p>
                    </div>
                </div>

                <!-- Small Portfolio Item + Text -->
                <div class="md:col-span-8 flex flex-col justify-between space-y-8 md:space-y-0">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
                        <div class="space-y-2">
                            <div class="art-placeholder h-[300px]"></div>
                            <p class="font-serif-artistic text-sm uppercase tracking-wider">Heirloom Keepsakes</p>
                        </div>
                        <div class="space-y-2">
                            <div class="art-placeholder h-[300px]"></div>
                            <p class="font-serif-artistic text-sm uppercase tracking-wider">Commissioned Poetry</p>
                        </div>
                    </div>
                    <!-- Large Wide Portfolio Item -->
                    <div class="space-y-2 pt-8">
                        <div class="art-placeholder h-[250px]"></div>
                        <div class="flex justify-between items-center pt-2">
                            <p class="font-serif-artistic text-sm uppercase tracking-wider">Luxury Gift Wrapping & Custom Tags</p>
                            <p class="text-xs text-neutral-500">Bespoke Holiday Collection</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Services Section -->
    <section id="services" class="py-24 max-w-6xl mx-auto px-6 reveal">
        <div class="text-center mb-16">
            <span class="font-serif-artistic text-xs uppercase tracking-widest text-[#C5A880]">— What We Create</span>
            <h2 class="font-serif-artistic text-3xl md:text-4xl uppercase tracking-widest mt-2">Bespoke Offerings</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
            <!-- Service 1 -->
            <div class="border border-[#C5A880]/30 p-8 flex flex-col justify-between h-[350px] hover:shadow-lg transition duration-300 bg-white">
                <div>
                    <span class="font-serif-artistic text-lg text-[#C5A880] block mb-4">01 //</span>
                    <h3 class="font-serif-artistic text-xl uppercase tracking-wide mb-4">Live Calligraphy</h3>
                    <p class="text-xs leading-relaxed text-neutral-600">
                        Add a luxurious touch to your live events or brand activations. Watch your guests' names turn into beautiful keepsakes in real-time.
                    </p>
                </div>
                <a href="#contact" class="text-xs uppercase tracking-widest font-semibold text-[#1C1B1A] hover:text-[#C5A880] transition self-start mt-4">Inquire →</a>
            </div>

            <!-- Service 2 -->
            <div class="border border-[#C5A880]/30 p-8 flex flex-col justify-between h-[350px] hover:shadow-lg transition duration-300 bg-white">
                <div>
                    <span class="font-serif-artistic text-lg text-[#C5A880] block mb-4">02 //</span>
                    <h3 class="font-serif-artistic text-xl uppercase tracking-wide mb-4">Personalized Gifts</h3>
                    <p class="text-xs leading-relaxed text-neutral-600">
                        From custom-written wedding vows and engraved perfume bottles to bespoke poetry layouts, tailored perfectly to the stories you share.
                    </p>
                </div>
                <a href="#contact" class="text-xs uppercase tracking-widest font-semibold text-[#1C1B1A] hover:text-[#C5A880] transition self-start mt-4">Inquire →</a>
            </div>

            <!-- Service 3 -->
            <div class="border border-[#C5A880]/30 p-8 flex flex-col justify-between h-[350px] hover:shadow-lg transition duration-300 bg-white">
                <div>
                    <span class="font-serif-artistic text-lg text-[#C5A880] block mb-4">03 //</span>
                    <h3 class="font-serif-artistic text-xl uppercase tracking-wide mb-4">Event Stationery</h3>
                    <p class="text-xs leading-relaxed text-neutral-600">
                        Invitations, placement cards, menus, and custom signage that set a striking, romantic tone for your most intimate celebrations.
                    </p>
                </div>
                <a href="#contact" class="text-xs uppercase tracking-widest font-semibold text-[#1C1B1A] hover:text-[#C5A880] transition self-start mt-4">Inquire →</a>
            </div>
        </div>
    </section>

    <!-- Call to Action / Contact Form -->
    <section id="contact" class="py-24 bg-[#1C1B1A] text-[#FDFBF7] relative overflow-hidden reveal">
        <!-- Abstract glowing orb -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-[#C5A880]/5 filter blur-3xl pointer-events-none"></div>

        <div class="max-w-4xl mx-auto px-6 relative z-10">
            <div class="text-center mb-12">
                <span class="font-calligraphy text-4xl text-[#C5A880] block mb-2">begin your journey</span>
                <h2 class="font-serif-artistic text-3xl md:text-4xl uppercase tracking-widest">Inquire & Create</h2>
                <p class="text-xs tracking-wider text-neutral-400 mt-4 max-w-md mx-auto">
                    Let's collaborate on something extraordinary. Drop your thoughts below, and let the nib find its voice.
                </p>
            </div>

            <form class="space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <input type="text" placeholder="Your Name" class="w-full bg-transparent border-b border-[#C5A880]/30 py-3 text-sm focus:outline-none focus:border-[#C5A880] transition placeholder-neutral-500">
                    <input type="email" placeholder="Your Email" class="w-full bg-transparent border-b border-[#C5A880]/30 py-3 text-sm focus:outline-none focus:border-[#C5A880] transition placeholder-neutral-500">
                </div>
                <input type="text" placeholder="Project Type (e.g., Vows, Calligraphy, Wedding)" class="w-full bg-transparent border-b border-[#C5A880]/30 py-3 text-sm focus:outline-none focus:border-[#C5A880] transition placeholder-neutral-500">
                <textarea placeholder="Tell us about your vision..." rows="4" class="w-full bg-transparent border-b border-[#C5A880]/30 py-3 text-sm focus:outline-none focus:border-[#C5A880] transition placeholder-neutral-500"></textarea>
                
                <div class="text-center pt-6">
                    <button type="submit" class="bg-[#C5A880] text-[#1C1B1A] px-10 py-4 text-xs uppercase tracking-widest hover:bg-[#FDFBF7] hover:text-[#1C1B1A] transition duration-300 font-semibold">Send Inquiry</button>
                </div>
            </form>
        </div>
    </section>

    <!-- Footer -->
    <footer class="py-12 border-t border-[#C5A880]/20 text-center text-xs tracking-widest text-neutral-500">
        <p class="font-serif-artistic uppercase text-[#1C1B1A] mb-3">The Ink Studio</p>
        <p>&copy; 2026 The Ink Studio. Crafted with intent.</p>
    </footer>

    <!-- Scroll Reveal JavaScript -->
    <script>
        function reveal() {
            var reveals = document.querySelectorAll(".reveal");
            for (var i = 0; i < reveals.length; i++) {
                var windowHeight = window.innerHeight;
                var elementTop = reveals[i].getBoundingClientRect().top;
                var elementVisible = 150;
                if (elementTop < windowHeight - elementVisible) {
                    reveals[i].classList.add("active");
                }
            }
        }
        window.addEventListener("scroll", reveal);
        // Trigger once on load in case some elements are already visible
        reveal();
    </script>
</body>
</html>
